# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# WhatsApp Business API (Meta Graph API)
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token

# SMS fallback (Africa's Talking or similar)
SMS_API_KEY=
SMS_API_URL=
SMS_USERNAME=
SMS_SENDER_ID=DukaOS

# TRA VFD provider
VFD_API_URL=https://vfd.provider.co.tz/api/v1
VFD_API_KEY=your-vfd-api-key

# Worker security
WORKER_SECRET=change-this-to-a-strong-random-secret

# Server
PORT=3001
